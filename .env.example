# API Keys — Copie este arquivo para .env e adicione suas chaves
# NUNCA commite o arquivo .env no git!

# OpenAI API (obrigatória — motor de IA do jogo)
# Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...sua_chave_aqui

# Modelos OpenAI por agente (opcional — fallback para OPENAI_MODEL se não definido)
# Arquivista: tarefa mecânica (JSON→JSON), roda a cada turno
OPENAI_MODEL_ARQUIVISTA=gpt-4o-mini
# Mestre do Jogo: narração RPG + tags estruturadas, roda a cada turno
OPENAI_MODEL_MESTRE=gpt-4o-mini
# Mestre do Conto: qualidade literária, contexto longo, roda raramente
OPENAI_MODEL_CONTO=gpt-4.1
# Fallback genérico (usado se os acima não forem definidos)
OPENAI_MODEL=gpt-4o-mini

# Google Cloud TTS — vozes neurais em pt-BR
# Obter em: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
GOOGLE_APPLICATION_CREDENTIALS=dragonsbreath-55a792adeda7.json
GOOGLE_CLOUD_PROJECT=dragonsbreath

# Vozes do Google Cloud TTS (Neural2 = alta qualidade / Journey = premium)
# Opções masculinas:  pt-BR-Neural2-B, pt-BR-Neural2-D, pt-BR-Journey-D, pt-BR-Studio-B
# Opções femininas:   pt-BR-Neural2-A, pt-BR-Neural2-C, pt-BR-Journey-F, pt-BR-Journey-O
GOOGLE_TTS_VOICE_MASTER=pt-BR-Neural2-B
GOOGLE_TTS_VOICE_NARRATOR=pt-BR-Neural2-A

# Freesound.org (gratuito — SFX contextuais ilimitados)
# Criar conta e API key em: https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=sua_chave_freesound_aqui

# ElevenLabs TTS (opcional — alternativa premium de voz)
# Obter em: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...sua_chave_aqui
