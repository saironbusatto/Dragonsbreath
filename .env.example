# API Keys - COPIE ESTE ARQUIVO PARA .env E ADICIONE SUAS CHAVES
# NÃO COMMITE O ARQUIVO .env NO GIT!

# Gemini API (obrigatória para IA do jogo)
GEMINI_API_KEY=sua_chave_gemini_aqui

# ElevenLabs API (opcional - backup para TTS premium)
ELEVENLABS_API_KEY=sua_chave_elevenlabs_aqui

# Google Cloud TTS (recomendado - mais barato e qualidade alta)
GOOGLE_APPLICATION_CREDENTIALS=seu_arquivo_google_cloud.json
GOOGLE_CLOUD_PROJECT=seu_projeto_google_cloud
